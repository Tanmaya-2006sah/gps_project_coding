<div class="container-fluid vh-100">
  <div class="row h-100">
    <!-- Left side - Professional Info -->
    <div class="col-md-6 bg-success text-white d-flex align-items-center justify-content-center">
      <div class="text-center">
        <div class="mb-4">
          <i class="bi bi-person-badge" style="font-size: 4rem;"></i>
        </div>
        <h1 class="h2 mb-3">Join Our Platform</h1>
        <p class="lead mb-4">Register as a Healthcare Professional</p>
        <div class="row text-center">
          <div class="col">
            <i class="bi bi-shield-check-fill d-block mb-2" style="font-size: 2rem;"></i>
            <small>Secure Platform</small>
          </div>
          <div class="col">
            <i class="bi bi-people-fill d-block mb-2" style="font-size: 2rem;"></i>
            <small>Multiple Patients</small>
          </div>
          <div class="col">
            <i class="bi bi-clock-fill d-block mb-2" style="font-size: 2rem;"></i>
            <small>24/7 Monitoring</small>
          </div>
        </div>
      </div>
    </div>

    <!-- Right side - Registration Form -->
    <div class="col-md-6 d-flex align-items-center justify-content-center">
      <div class="w-100" style="max-width: 450px;">
        <div class="text-center mb-4">
          <h2 class="h3 mb-3 text-success">Healthcare Professional Registration</h2>
          <p class="text-muted">Create your professional account</p>
        </div>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), local: true, class: "needs-validation", novalidate: true) do |f| %>
          <%= render "caretakers/shared/error_messages", resource: resource %>

          <div class="row mb-3">
            <div class="col-6">
              <%= f.label :first_name, class: "form-label" %>
              <%= f.text_field :first_name, class: "form-control", placeholder: "First name", required: true %>
              <div class="invalid-feedback">Please provide your first name.</div>
            </div>
            <div class="col-6">
              <%= f.label :last_name, class: "form-label" %>
              <%= f.text_field :last_name, class: "form-control", placeholder: "Last name", required: true %>
              <div class="invalid-feedback">Please provide your last name.</div>
            </div>
          </div>

          <div class="mb-3">
            <%= f.label :email, "Professional Email", class: "form-label" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "your.email@hospital.com", required: true %>
            <div class="invalid-feedback">Please provide a valid email address.</div>
          </div>

          <div class="mb-3">
            <%= f.label :phone, class: "form-label" %>
            <%= f.telephone_field :phone, class: "form-control", placeholder: "+1-555-0123" %>
          </div>

          <div class="mb-3">
            <%= f.label :license_number, "Medical License Number", class: "form-label" %>
            <%= f.text_field :license_number, class: "form-control", placeholder: "License number", required: true %>
            <div class="invalid-feedback">Please provide your license number.</div>
          </div>

          <div class="mb-3">
            <%= f.label :specialization, class: "form-label" %>
            <%= f.select :specialization, 
                options_for_select([
                  ['Geriatrician', 'geriatrician'],
                  ['Neurologist', 'neurologist'],
                  ['Psychiatrist', 'psychiatrist'],
                  ['General Practitioner', 'general_practitioner'],
                  ['Nurse', 'nurse'],
                  ['Social Worker', 'social_worker'],
                  ['Other', 'other']
                ]), 
                { prompt: 'Select specialization' }, 
                { class: "form-select", required: true } %>
            <div class="invalid-feedback">Please select your specialization.</div>
          </div>

          <div class="mb-3">
            <%= f.label :years_experience, "Years of Experience", class: "form-label" %>
            <%= f.number_field :years_experience, class: "form-control", min: 0, max: 50, placeholder: "Years", required: true %>
            <div class="invalid-feedback">Please provide your years of experience.</div>
          </div>

          <div class="mb-3">
            <%= f.label :password, class: "form-label" %>
            <% if @minimum_password_length %>
              <small class="text-muted">(<%= @minimum_password_length %> characters minimum)</small>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "Create password", required: true %>
            <div class="invalid-feedback">Password must be at least <%= @minimum_password_length || 6 %> characters.</div>
          </div>

          <div class="mb-3">
            <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "Confirm password", required: true %>
            <div class="invalid-feedback">Passwords must match.</div>
          </div>

          <div class="mb-3 form-check">
            <%= f.check_box :terms_accepted, { class: "form-check-input", required: true }, "1", "" %>
            <%= f.label :terms_accepted, class: "form-check-label" do %>
              I agree to the <a href="#" class="text-success">Terms of Service</a> and <a href="#" class="text-success">Privacy Policy</a>
            <% end %>
            <div class="invalid-feedback">Please accept the terms and conditions.</div>
          </div>

          <div class="d-grid mb-3">
            <%= f.submit "Create Account", class: "btn btn-success btn-lg" %>
          </div>
        <% end %>
        
        <div class="text-center">
          <small class="text-muted">
            Already have an account? 
            <%= link_to "Sign in here", new_session_path(resource_name), class: "text-success text-decoration-none fw-bold" %>
          </small>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Form validation
  const form = document.querySelector('.needs-validation');
  const passwordField = document.querySelector('#caretaker_password');
  const passwordConfirmField = document.querySelector('#caretaker_password_confirmation');
  
  // Custom validation for password confirmation
  function validatePasswordConfirmation() {
    if (passwordField.value !== passwordConfirmField.value) {
      passwordConfirmField.setCustomValidity("Passwords don't match");
    } else {
      passwordConfirmField.setCustomValidity('');
    }
  }
  
  passwordField.addEventListener('change', validatePasswordConfirmation);
  passwordConfirmField.addEventListener('keyup', validatePasswordConfirmation);
  
  form.addEventListener('submit', function(event) {
    if (!form.checkValidity()) {
      event.preventDefault();
      event.stopPropagation();
    }
    form.classList.add('was-validated');
  });
});
</script>

<style>
body {
  background: linear-gradient(135deg, #28a745 0%, #20c997 100%) !important;
}

.vh-100 {
  min-height: 100vh;
}

@media (max-width: 768px) {
  .col-md-6:first-child {
    display: none;
  }
}
</style>

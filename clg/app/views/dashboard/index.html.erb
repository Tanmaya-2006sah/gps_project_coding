          </div>
        <% else %>
          <div class="text-center py-4">
            <i class="bi bi-activity display-4 text-muted mb-2"></i>
            <p class="text-muted mb-0">No recent activity recorded</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Recent Notifications -->
<% if @recent_notifications.any? %>
  <div class="row g-4 mt-1">
    <div class="col-12">
      <div class="card">
        <div class="card-header bg-white border-bottom">
          <div class="d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">
              <i class="bi bi-bell-fill me-2 text-warning"></i>
              Recent Notifications
            </h5>
            <%= link_to "View All", notifications_path, class: "btn btn-outline-primary btn-sm" %>
          </div>
        </div>
        <div class="card-body">
          <% @recent_notifications.each do |notification| %>
            <div class="alert alert-<%= notification.priority == 'critical' ? 'danger' : notification.priority == 'high' ? 'warning' : 'info' %> alert-dismissible" role="alert">
              <div class="d-flex align-items-start">
                <i class="<%= notification.type_icon %> me-2 mt-1"></i>
                <div class="flex-grow-1">
                  <h6 class="alert-heading mb-1"><%= notification.title %></h6>
                  <p class="mb-1"><%= notification.message %></p>
                  <div class="small">
                    <% if notification.patient %>
                      Patient: <strong><%= notification.patient.name %></strong> • 
                    <% end %>
                    <%= notification.time_ago %>
                  </div>
                </div>
                <span class="badge bg-<%= notification.priority == 'critical' ? 'danger' : notification.priority == 'high' ? 'warning' : 'secondary' %>">
                  <%= notification.priority.capitalize %>
                </span>
              </div>
              
              <%= link_to "×", notification_path(notification, format: :json), 
                  method: :patch, 
                  remote: true, 
                  class: "btn-close", 
                  "aria-label": "Close",
                  data: { "turbo-method": "patch", action: "notification#mark_as_read" } %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<!-- Leaflet CSS and JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Initialize the live map
  initializeLiveMap();
  
  // Set up real-time updates
  setupRealTimeUpdates();
  
  // Refresh buttons
  document.getElementById('refreshMap')?.addEventListener('click', refreshMap);
  document.getElementById('centerMap')?.addEventListener('click', centerMap);
  document.getElementById('refreshVitals')?.addEventListener('click', refreshAllVitals);
});

let liveMap;
let patientMarkers = {};

// Initialize the live tracking map
function initializeLiveMap() {
  // Initialize map centered on first patient or default location
  <% if @patients.any? && @patients.first.latitude && @patients.first.longitude %>
    const centerLat = <%= @patients.first.latitude %>;
    const centerLng = <%= @patients.first.longitude %>;
  <% else %>
    const centerLat = 40.7128;
    const centerLng = -74.0060;
  <% end %>
  
  liveMap = L.map('liveMap').setView([centerLat, centerLng], 12);
  
  // Add OpenStreetMap tiles
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors'
  }).addTo(liveMap);
  
  // Add patient markers
  <% @patients.each do |patient| %>
    <% if patient.latitude && patient.longitude %>
      addPatientMarker(<%= patient.id %>, {
        lat: <%= patient.latitude %>,
        lng: <%= patient.longitude %>,
        name: '<%= j patient.name %>',
        status: '<%= patient.location_status %>',
        lastSeen: '<%= patient.last_seen_at ? time_ago_in_words(patient.last_seen_at) : 'Never' %>'
      });
      
      // Add geofence zones for this patient
      <% patient.geofence_zones.active.each do |zone| %>
        addGeofenceZone(<%= zone.id %>, {
          lat: <%= zone.center_latitude %>,
          lng: <%= zone.center_longitude %>,
          radius: <%= zone.radius_meters %>,
          name: '<%= j zone.name %>',
          patientName: '<%= j patient.name %>'
        });
      <% end %>
    <% end %>
  <% end %>
}

// Add patient marker to map
function addPatientMarker(patientId, data) {
  const statusColors = {
    'safe': '#28a745',
    'away': '#ffc107', 
    'outside_zone': '#dc3545',
    'offline': '#6c757d'
  };
  
  const marker = L.circleMarker([data.lat, data.lng], {
    radius: 10,
    fillColor: statusColors[data.status] || '#6c757d',
    color: '#ffffff',
    weight: 2,
    opacity: 1,
    fillOpacity: 0.8
  }).addTo(liveMap);
  
  const popupContent = `
    <div class="text-center">
      <h6 class="mb-2">${data.name}</h6>
      <span class="badge bg-${getStatusBootstrapColor(data.status)}">${data.status.replace('_', ' ').toUpperCase()}</span>
      <div class="small text-muted mt-1">
        Last seen: ${data.lastSeen} ago
      </div>
      <div class="small mt-1">
        <button class="btn btn-sm btn-primary" onclick="viewPatientDetails(${patientId})">
          View Details
        </button>
      </div>
    </div>
  `;
  
  marker.bindPopup(popupContent);
  patientMarkers[patientId] = marker;
}

// Add geofence zone to map
function addGeofenceZone(zoneId, data) {
  const circle = L.circle([data.lat, data.lng], {
    radius: data.radius,
    color: '#007bff',
    fillColor: '#007bff',
    fillOpacity: 0.1,
    weight: 2,
    dashArray: '5, 5'
  }).addTo(liveMap);
  
  circle.bindPopup(`
    <div class="text-center">
      <h6 class="mb-1">${data.name}</h6>
      <div class="small text-muted">Safe Zone for ${data.patientName}</div>
      <div class="small">Radius: ${(data.radius / 1000).toFixed(2)} km</div>
    </div>
  `);
}

// Helper function to get Bootstrap color class
function getStatusBootstrapColor(status) {
  const colorMap = {
    'safe': 'success',
    'away': 'warning', 
    'outside_zone': 'danger',
    'offline': 'secondary'
  };
  return colorMap[status] || 'secondary';
}

// Refresh map data
function refreshMap() {
  // Show loading state
  document.getElementById('refreshMap').innerHTML = '<i class="bi bi-arrow-clockwise spin me-1"></i>Refreshing...';
  
  // Simulate API call - in real implementation, fetch from server
  setTimeout(() => {
    document.getElementById('refreshMap').innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Refresh';
    
    // Update marker positions (in real app, get from API)
    Object.keys(patientMarkers).forEach(patientId => {
      // Add small random movement for demo
      const marker = patientMarkers[patientId];
      const currentPos = marker.getLatLng();
      const newPos = {
        lat: currentPos.lat + (Math.random() - 0.5) * 0.001,
        lng: currentPos.lng + (Math.random() - 0.5) * 0.001
      };
      marker.setLatLng(newPos);
    });
  }, 1000);
}

// Center map on all patients
function centerMap() {
  if (Object.keys(patientMarkers).length > 0) {
    const group = new L.featureGroup(Object.values(patientMarkers));
    liveMap.fitBounds(group.getBounds().pad(0.1));
  }
}

// Set up real-time updates
function setupRealTimeUpdates() {
  // Update every 30 seconds
  setInterval(() => {
    refreshAllVitals();
    updatePatientLocations();
  }, 30000);
}

// Refresh all vital signs
function refreshAllVitals() {
  document.getElementById('refreshVitals').innerHTML = '<i class="bi bi-arrow-clockwise spin me-1"></i>Refreshing...';
  
  // In a real app, make AJAX call to fetch latest vitals
  fetch('/api/v1/vitals/latest', {
    headers: {
      'Accept': 'application/json',
      'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
    }
  })
  .then(response => response.json())
  .then(data => {
    updateVitalsDisplay(data);
    document.getElementById('refreshVitals').innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Refresh';
  })
  .catch(error => {
    console.error('Error refreshing vitals:', error);
    document.getElementById('refreshVitals').innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Refresh';
  });
}

// Refresh specific patient vitals
function refreshPatientVitals(patientId) {
  // In a real app, make AJAX call to fetch specific patient vitals
  fetch(`/api/v1/patients/${patientId}/vital_signs`, {
    headers: {
      'Accept': 'application/json',
      'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
    }
  })
  .then(response => response.json())
  .then(data => {
    updateSinglePatientVitals(patientId, data);
  })
  .catch(error => {
    console.error('Error refreshing patient vitals:', error);
  });
}

// Update vitals display
function updateVitalsDisplay(vitalsData) {
  vitalsData.forEach(vital => {
    const patientId = vital.patient_id;
    
    // Update vital signs display
    document.getElementById(`heartRate-${patientId}`).textContent = vital.heart_rate;
    document.getElementById(`bloodPressure-${patientId}`).textContent = 
      `${vital.blood_pressure_systolic}/${vital.blood_pressure_diastolic}`;
    document.getElementById(`temperature-${patientId}`).textContent = `${parseFloat(vital.temperature).toFixed(2)}°F`;
    document.getElementById(`lastUpdate-${patientId}`).textContent = 
      `Last update: ${vital.time_ago} ago`;
    
    // Update status badge
    const statusElement = document.getElementById(`vitalStatus-${patientId}`);
    statusElement.className = `badge bg-${vital.status_color}`;
    statusElement.textContent = vital.status.charAt(0).toUpperCase() + vital.status.slice(1);
  });
}

// Update patient locations
function updatePatientLocations() {
  // In a real app, fetch latest location data
  fetch('/api/v1/patients/locations', {
    headers: {
      'Accept': 'application/json',
      'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
    }
  })
  .then(response => response.json())
  .then(data => {
    data.forEach(location => {
      if (patientMarkers[location.patient_id]) {
        const marker = patientMarkers[location.patient_id];
        marker.setLatLng([location.latitude, location.longitude]);
        
        // Update marker color based on status
        const statusColors = {
          'safe': '#28a745',
          'away': '#ffc107', 
          'outside_zone': '#dc3545',
          'offline': '#6c757d'
        };
        marker.setStyle({
          fillColor: statusColors[location.status] || '#6c757d'
        });
      }
    });
  })
  .catch(error => {
    console.error('Error updating locations:', error);
  });
}

// Navigate to patient details
function viewPatientDetails(patientId) {
  window.location.href = `/patients/${patientId}`;
}


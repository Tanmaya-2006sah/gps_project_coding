<!-- Live Dashboard Container -->
<div class="live-dashboard-container">

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="fw-bold text-dark mb-1">Patient Monitoring Dashboard</h2>
    <p class="text-muted mb-0">Real-time overview of patient health and location</p>
  </div>
  <div>
    <%= link_to "Add Patient", new_patient_path, class: "btn btn-primary" %>
  </div>
</div>

<!-- Dashboard Statistics Cards -->
<div class="row g-4 mb-4">
  <div class="col-xl-3 col-md-6">
    <div class="card bg-primary text-white h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="fs-2 fw-bold" data-stat="total-patients"><%= @total_patients %></div>
            <div>Total Patients</div>
          </div>
          <div class="fs-1 opacity-75">
            <i class="bi bi-people-fill"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="col-xl-3 col-md-6">
    <div class="card bg-success text-white h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="fs-2 fw-bold" data-stat="patients-safe"><%= @patients_in_safe_zones %></div>
            <div>In Safe Zones</div>
          </div>
          <div class="fs-1 opacity-75">
            <i class="bi bi-shield-check"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="col-xl-3 col-md-6">
    <div class="card bg-warning text-white h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="fs-2 fw-bold" data-stat="unread-alerts"><%= current_user.unread_notifications_count %></div>
            <div>Unread Alerts</div>
          </div>
          <div class="fs-1 opacity-75">
            <i class="bi bi-bell-fill"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="col-xl-3 col-md-6">
    <div class="card bg-danger text-white h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="fs-2 fw-bold" data-stat="critical-alerts"><%= @critical_alerts %></div>
            <div>Critical Alerts</div>
          </div>
          <div class="fs-1 opacity-75">
            <i class="bi bi-exclamation-triangle-fill"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Live Location Map -->
<div class="row g-4 mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header bg-white border-bottom">
        <div class="d-flex justify-content-between align-items-center">
          <h5 class="card-title mb-0">
            <i class="bi bi-map me-2 text-success"></i>
            Live Patient Location Tracking
          </h5>
          <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-primary" id="refreshMap">
              <i class="bi bi-arrow-clockwise me-1"></i>Refresh
            </button>
            <button class="btn btn-sm btn-outline-success" id="centerMap">
              <i class="bi bi-geo-alt me-1"></i>Center View
            </button>
          </div>
        </div>
      </div>
      <div class="card-body p-0">
        <div id="liveMap" style="height: 400px; width: 100%;"></div>
        <div class="p-3 bg-light border-top">
          <div class="d-flex flex-wrap gap-3">
            <div class="d-flex align-items-center">
              <div class="bg-success rounded-circle me-2" style="width: 12px; height: 12px;"></div>
              <small>Safe Zone</small>
            </div>
            <div class="d-flex align-items-center">
              <div class="bg-warning rounded-circle me-2" style="width: 12px; height: 12px;"></div>
              <small>Away</small>
            </div>
            <div class="d-flex align-items-center">
              <div class="bg-danger rounded-circle me-2" style="width: 12px; height: 12px;"></div>
              <small>Outside Zone</small>
            </div>
            <div class="d-flex align-items-center">
              <div class="bg-secondary rounded-circle me-2" style="width: 12px; height: 12px;"></div>
              <small>Offline</small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Main Content Row -->
<div class="row g-4">
  <!-- Patient Status Cards -->
  <div class="col-lg-8">
    <div class="card h-100">
      <div class="card-header bg-white border-bottom">
        <h5 class="card-title mb-0">
          <i class="bi bi-people-fill me-2 text-primary"></i>
          Patient Status Overview
        </h5>
      </div>
      <div class="card-body">
        <% if @patients.any? %>
          <div class="row g-3">
            <% @patients.each do |patient| %>
              <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                  <div class="d-flex justify-content-between align-items-start mb-2">
                    <h6 class="mb-0 fw-bold"><%= patient.name %></h6>
                    <span class="badge bg-<%= patient.status_color %>">
                      <%= patient.location_status.humanize %>
                    </span>
                  </div>
                  
                  <div class="small text-muted mb-2">
                    <i class="bi bi-person me-1"></i>
                    <%= patient.age %> years, <%= patient.gender.capitalize %>
                  </div>
                  
                  <% if patient.latitude && patient.longitude %>
                    <div class="small mb-2">
                      <i class="bi bi-geo-alt-fill me-1 text-primary"></i>
                      Location: <%= patient.latitude.round(4) %>, <%= patient.longitude.round(4) %>
                    </div>
                  <% end %>
                  
                  <% if patient.last_seen_at %>
                    <div class="small mb-2">
                      <i class="bi bi-clock me-1 text-muted"></i>
                      Last seen: <%= time_ago_in_words(patient.last_seen_at) %> ago
                    </div>
                  <% end %>
                  
                  <% latest_vitals = patient.latest_vital_signs %>
                  <% if latest_vitals %>
                    <div class="small mb-2">
                      <span class="badge bg-<%= latest_vitals.status_color %> me-1">
                        <i class="bi bi-heart-pulse-fill"></i>
                      </span>
                      HR: <%= latest_vitals.heart_rate %> | 
                      BP: <%= latest_vitals.blood_pressure_systolic %>/<%= latest_vitals.blood_pressure_diastolic %>
                    </div>
                  <% end %>
                  
                  <div class="mt-2">
                    <%= link_to "View Details", patient, class: "btn btn-sm btn-outline-primary" %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-5">
            <i class="bi bi-people display-1 text-muted mb-3"></i>
            <h5 class="text-muted">No Patients Added</h5>
            <p class="text-muted">Start monitoring by adding your first patient.</p>
            <%= link_to "Add Patient", new_patient_path, class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  
  <!-- Vital Signs Summary -->
  <div class="col-lg-4">
    <div class="card h-100">
      <div class="card-header bg-white border-bottom">
        <h5 class="card-title mb-0">
          <i class="bi bi-activity me-2 text-success"></i>
          Recent Vital Signs
        </h5>
      </div>
      <div class="card-body">
        <% if @vital_signs_data.any? %>
          <% @vital_signs_data.each do |vital_data| %>
            <div class="border-bottom pb-2 mb-2">
              <div class="d-flex justify-content-between align-items-center">
                <strong class="small"><%= vital_data[:patient] %></strong>
                <span class="badge bg-<%= vital_data[:status] == 'normal' ? 'success' : vital_data[:status] == 'warning' ? 'warning' : 'danger' %>">
                  <%= vital_data[:status].capitalize %>
                </span>
              </div>
              <div class="small text-muted">
                <div>❤️ <%= vital_data[:heart_rate] %> BPM</div>
                <div>🩸 <%= vital_data[:blood_pressure] %> mmHg</div>
                <div>🌡️ <%= vital_data[:temperature] %>°F</div>
                <div class="text-muted">
                  <%= time_ago_in_words(vital_data[:recorded_at]) %> ago
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-4">
            <i class="bi bi-heart-pulse display-4 text-muted mb-2"></i>
            <p class="text-muted small mb-0">No vital signs recorded yet</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Real-time Vital Signs Monitoring -->
<div class="row g-4 mt-1">
  <div class="col-12">
    <div class="card">
      <div class="card-header bg-white border-bottom">
        <div class="d-flex justify-content-between align-items-center">
          <h5 class="card-title mb-0">
            <i class="bi bi-heart-pulse me-2 text-danger"></i>
            Live Vital Signs Monitor
          </h5>
          <div class="d-flex gap-2">
            <span class="badge bg-success" id="vitalsStatus">
              <i class="bi bi-wifi me-1"></i>Connected
            </span>
            <button class="btn btn-sm btn-outline-primary" id="refreshVitals">
              <i class="bi bi-arrow-clockwise me-1"></i>Refresh
            </button>
          </div>
        </div>
      </div>
      <div class="card-body">
        <% if @patients.any? %>
          <div class="row g-3" id="vitalsContainer">
            <% @patients.each do |patient| %>
              <div class="col-md-6 col-xl-4">
                <div class="border rounded p-3 patient-vitals" data-patient-id="<%= patient.id %>">
                  <div class="d-flex justify-content-between align-items-start mb-2">
                    <h6 class="mb-0 fw-bold"><%= patient.name %></h6>
                    <% latest_vitals = patient.latest_vital_signs %>
                    <% if latest_vitals %>
                      <span class="badge bg-<%= latest_vitals.status_color %>" id="vitalStatus-<%= patient.id %>">
                        <%= latest_vitals.status.humanize %>
                      </span>
                    <% else %>
                      <span class="badge bg-secondary" id="vitalStatus-<%= patient.id %>">
                        No Data
                      </span>
                    <% end %>
                  </div>
                  
                  <div class="vital-metrics">
                    <% if latest_vitals %>
                      <div class="row g-2 mb-2">
                        <div class="col-6">
                          <div class="text-center p-2 bg-light rounded">
                            <div class="text-danger fw-bold fs-5" id="heartRate-<%= patient.id %>">
                              <%= latest_vitals.heart_rate %>
                            </div>
                            <small class="text-muted">❤️ BPM</small>
                          </div>
                        </div>
                        <div class="col-6">
                          <div class="text-center p-2 bg-light rounded">
                            <div class="text-primary fw-bold fs-6" id="bloodPressure-<%= patient.id %>">
                              <%= latest_vitals.blood_pressure_systolic %>/<%= latest_vitals.blood_pressure_diastolic %>
                            </div>
                            <small class="text-muted">🩸 mmHg</small>
                          </div>
                        </div>
                      </div>
                      <div class="text-center p-2 bg-light rounded mb-2">
                        <div class="text-warning fw-bold" id="temperature-<%= patient.id %>">
                          <%= latest_vitals.temperature&.round(2) %>°F
                        </div>
                        <small class="text-muted">🌡️ Temperature</small>
                      </div>
                      <div class="small text-muted text-center" id="lastUpdate-<%= patient.id %>">
                        Last update: <%= time_ago_in_words(latest_vitals.recorded_at) %> ago
                      </div>
                    <% else %>
                      <div class="text-center py-3">
                        <i class="bi bi-heart-pulse text-muted display-6"></i>
                        <div class="small text-muted">No vital signs data</div>
                      </div>
                    <% end %>
                  </div>
                  
                  <div class="mt-2 d-flex gap-1">
                    <%= link_to "View History", patient, class: "btn btn-sm btn-outline-primary flex-fill" %>
                    <button class="btn btn-sm btn-outline-success" onclick="refreshPatientVitals(<%= patient.id %>)">
                      <i class="bi bi-arrow-clockwise"></i>
                    </button>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-5">
            <i class="bi bi-heart-pulse display-1 text-muted mb-3"></i>
            <h5 class="text-muted">No Patients to Monitor</h5>
            <p class="text-muted">Add patients to start monitoring their vital signs.</p>
            <%= link_to "Add Patient", new_patient_path, class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Recent Activity Feed -->

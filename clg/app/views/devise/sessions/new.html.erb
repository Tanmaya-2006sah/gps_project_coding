<div class="container-fluid vh-100">
  <div class="row h-100">
    <!-- Left side - App Info -->
    <div class="col-md-6 bg-primary text-white d-flex align-items-center justify-content-center">
      <div class="text-center">
        <div class="mb-4">
          <i class="bi bi-heart-pulse-fill" style="font-size: 4rem;"></i>
        </div>
        <h1 class="h2 mb-3">Patient Monitor</h1>
        <p class="lead mb-4">Advanced Alzheimer's Patient Monitoring System</p>
        <div class="row text-center">
          <div class="col">
            <i class="bi bi-geo-alt-fill d-block mb-2" style="font-size: 2rem;"></i>
            <small>Location Tracking</small>
          </div>
          <div class="col">
            <i class="bi bi-activity d-block mb-2" style="font-size: 2rem;"></i>
            <small>Vital Signs</small>
          </div>
          <div class="col">
            <i class="bi bi-shield-check-fill d-block mb-2" style="font-size: 2rem;"></i>
            <small>Safety Zones</small>
          </div>
        </div>
      </div>
    </div>

    <!-- Right side - Login Form -->
    <div class="col-md-6 d-flex align-items-center justify-content-center">
      <div class="w-100" style="max-width: 400px;">
        <div class="text-center mb-4">
          <h2 class="h3 mb-3">Welcome Back</h2>
          <p class="text-muted">Sign in to monitor your patients</p>
        </div>

        <!-- Login Type Selection -->
        <div class="row mb-4" id="loginTypeSelection">
          <div class="col-6">
            <div class="card border-primary login-type-card" data-type="user" style="cursor: pointer;">
              <div class="card-body text-center py-3">
                <i class="bi bi-person-heart text-primary mb-2" style="font-size: 2rem;"></i>
                <h6 class="card-title mb-1">Family Member</h6>
                <small class="text-muted">Monitor your loved ones</small>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div class="card border-secondary login-type-card" data-type="caretaker" style="cursor: pointer;">
              <div class="card-body text-center py-3">
                <i class="bi bi-person-badge text-secondary mb-2" style="font-size: 2rem;"></i>
                <h6 class="card-title mb-1">Healthcare Professional</h6>
                <small class="text-muted">Professional monitoring</small>
              </div>
            </div>
          </div>
        </div>

        <!-- User Login Form -->
        <div class="login-form" id="userLoginForm" style="display: none;">
          <div class="text-center mb-3">
            <h5 class="text-primary">Family Member Login</h5>
          </div>
          <%= form_for(resource, as: resource_name, url: session_path(resource_name), local: true, class: "needs-validation", novalidate: true) do |f| %>
            <div class="mb-3">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "Enter your email", required: true %>
              <div class="invalid-feedback">
                Please provide a valid email address.
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :password, class: "form-label" %>
              <%= f.password_field :password, autocomplete: "current-password", class: "form-control", placeholder: "Enter your password", required: true %>
              <div class="invalid-feedback">
                Please provide your password.
              </div>
            </div>

            <% if devise_mapping.rememberable? %>
              <div class="mb-3 form-check">
                <%= f.check_box :remember_me, class: "form-check-input" %>
                <%= f.label :remember_me, "Remember me", class: "form-check-label" %>
              </div>
            <% end %>

            <div class="d-grid mb-3">
              <%= f.submit "Sign In", class: "btn btn-primary" %>
            </div>
          <% end %>
          
          <div class="text-center">
            <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-decoration-none" %>
          </div>
          
          <div class="text-center mt-3">
            <small class="text-muted">
              Don't have an account? 
              <%= link_to "Sign up", new_registration_path(resource_name), class: "text-primary text-decoration-none" %>
            </small>
          </div>
        </div>

        <!-- Caretaker Redirect -->
        <div class="login-form" id="caretakerLoginForm" style="display: none;">
          <div class="text-center mb-4">
            <h5 class="text-success">Healthcare Professional Login</h5>
            <p class="text-muted">Redirecting to professional login...</p>
          </div>
          
          <div class="text-center">
            <div class="spinner-border text-success" role="status">
              <span class="visually-hidden">Loading...</span>
            </div>
          </div>
          
          <div class="text-center mt-3">
            <p class="text-muted">
              If you're not redirected automatically, 
              <%= link_to "click here", new_caretaker_session_path, class: "text-success" %>
            </p>
          </div>
        </div>

        <!-- Demo Credentials -->
        <div class="mt-4 p-3 bg-light rounded">
          <h6 class="text-muted mb-2">Demo Credentials</h6>
          <div class="small">
            <strong>Family Login:</strong><br>
            Email: demo@patientmonitor.com<br>
            Password: password123
          </div>
          <hr class="my-2">
          <div class="text-center">
            <small class="text-muted">Healthcare Professional?</small><br>
            <%= link_to "Professional Login", new_caretaker_session_path, class: "btn btn-sm btn-outline-success mt-1" %>
          </div>
        </div>

        <div class="text-center mt-3">
          <button type="button" class="btn btn-link btn-sm" id="backToSelection" style="display: none;">
            ← Back to login options
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const loginTypeCards = document.querySelectorAll('.login-type-card');
  const loginTypeSelection = document.getElementById('loginTypeSelection');
  const userLoginForm = document.getElementById('userLoginForm');
  const caretakerLoginForm = document.getElementById('caretakerLoginForm');
  const backToSelection = document.getElementById('backToSelection');

  loginTypeCards.forEach(card => {
    card.addEventListener('click', function() {
      const type = this.dataset.type;
      
      loginTypeSelection.style.display = 'none';
      backToSelection.style.display = 'inline-block';
      
      if (type === 'user') {
        userLoginForm.style.display = 'block';
        caretakerLoginForm.style.display = 'none';
      } else {
        // Redirect to caretaker login page
        caretakerLoginForm.style.display = 'block';
        userLoginForm.style.display = 'none';
        setTimeout(() => {
          window.location.href = '/caretakers/sign_in';
        }, 1000);
      }
    });
  });

  backToSelection.addEventListener('click', function() {
    loginTypeSelection.style.display = 'block';
    userLoginForm.style.display = 'none';
    caretakerLoginForm.style.display = 'none';
    this.style.display = 'none';
    
    // Reset card selections
    loginTypeCards.forEach(card => {
      card.classList.remove('border-primary', 'border-success');
      if (card.dataset.type === 'user') {
        card.classList.add('border-primary');
      } else {
        card.classList.add('border-secondary');
      }
    });
  });

  // Form validation
  const forms = document.querySelectorAll('.needs-validation');
  forms.forEach(form => {
    form.addEventListener('submit', function(event) {
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }
      form.classList.add('was-validated');
    });
  });
});
</script>

<style>
.login-type-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  transition: all 0.2s ease;
}

.sidebar-wrapper {
  display: none !important;
}

body {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
}

.vh-100 {
  min-height: 100vh;
}

@media (max-width: 768px) {
  .col-md-6:first-child {
    display: none;
  }
}
</style>

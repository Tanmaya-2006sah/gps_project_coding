<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h2 fw-bold">Create Geofence Zone</h1>
    <p class="text-muted mb-0">Set up a safety zone for <strong><%= @patient.name %></strong></p>
  </div>
  <div>
    <%= link_to geofence_zones_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>Back to Zones
    <% end %>
  </div>
</div>

<!-- Patient Info Card -->
<div class="row g-4">
  <div class="col-md-4">
    <div class="card border-primary">
      <div class="card-header bg-primary text-white">
        <h6 class="mb-0">
          <i class="bi bi-person-fill me-2"></i>Patient Information
        </h6>
      </div>
      <div class="card-body">
        <div class="d-flex align-items-center mb-3">
          <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
            <i class="bi bi-person-fill fs-4"></i>
          </div>
          <div>
            <h5 class="mb-1"><%= @patient.name %></h5>
            <small class="text-muted">Age: <%= @patient.age %> • <%= @patient.gender.humanize %></small>
          </div>
        </div>
        
        <div class="mb-3">
          <label class="form-label small text-muted">Current Location</label>
          <div class="d-flex align-items-center">
            <i class="bi bi-geo-alt-fill text-primary me-2"></i>
            <div>
              <div class="fw-semibold"><%= @patient.latitude.round(4) %>, <%= @patient.longitude.round(4) %></div>
              <small class="text-muted">Last seen: <%= time_ago_in_words(@patient.last_seen_at) %> ago</small>
            </div>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label small text-muted">Current Status</label>
          <div>
            <span class="badge bg-<%= @patient.location_status == 'safe' ? 'success' : @patient.location_status == 'away' ? 'warning' : 'danger' %> fs-6">
              <i class="bi bi-<%= @patient.location_status == 'safe' ? 'shield-check' : @patient.location_status == 'away' ? 'exclamation-triangle' : 'exclamation-circle' %> me-1"></i>
              <%= @patient.location_status.humanize %>
            </span>
          </div>
        </div>

        <div class="mb-0">
          <label class="form-label small text-muted">Medical Condition</label>
          <p class="small mb-0"><%= @patient.medical_condition %></p>
        </div>
      </div>
    </div>

    <!-- Existing Zones -->
    <% if @patient.geofence_zones.any? %>
      <div class="card mt-3">
        <div class="card-header">
          <h6 class="mb-0">
            <i class="bi bi-shield-check me-2"></i>Existing Zones (<%= @patient.geofence_zones.count %>)
          </h6>
        </div>
        <div class="card-body">
          <% @patient.geofence_zones.each do |zone| %>
            <div class="d-flex justify-content-between align-items-center p-2 bg-light rounded mb-2">
              <div>
                <div class="fw-semibold">
                  <i class="bi bi-<%= zone.active? ? 'shield-check' : 'shield-x' %> me-1 text-<%= zone.active? ? 'success' : 'secondary' %>"></i>
                  <%= zone.name %>
                </div>
                <small class="text-muted">Radius: <%= zone.radius_meters %>m</small>
              </div>
              <%= link_to [zone.patient, zone], class: "btn btn-sm btn-outline-primary" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Zone Creation Form -->
  <div class="col-md-8">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="bi bi-geo-alt-fill me-2"></i>Zone Configuration
        </h5>
      </div>
      <div class="card-body">
        <%= form_with model: [@patient, @geofence_zone], local: true, class: "needs-validation", novalidate: true do |form| %>
          <!-- Error Messages -->
          <% if @geofence_zone.errors.any? %>
            <div class="alert alert-danger">
              <h6>Please correct the following errors:</h6>
              <ul class="mb-0">
                <% @geofence_zone.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <!-- Zone Name -->
          <div class="mb-4">
            <%= form.label :name, "Zone Name", class: "form-label fw-semibold" %>
            <%= form.text_field :name, class: "form-control", placeholder: "e.g., Home Safe Zone, Park Area", required: true %>
            <div class="form-text">Choose a descriptive name for this safety zone</div>
            <div class="invalid-feedback">Please provide a zone name</div>
          </div>

          <!-- Quick Location Presets -->
          <div class="mb-4">
            <label class="form-label fw-semibold">Quick Location Presets</label>
            <div class="row g-2">
              <div class="col-md-4">
                <button type="button" class="btn btn-outline-primary w-100" onclick="useCurrentLocation()">
                  <i class="bi bi-crosshair me-1"></i>Patient's Current Location
                </button>
              </div>
              <div class="col-md-4">
                <button type="button" class="btn btn-outline-success w-100" onclick="useMapClick()">
                  <i class="bi bi-cursor me-1"></i>Click on Map
                </button>
              </div>
              <div class="col-md-4">
                <button type="button" class="btn btn-outline-info w-100" data-bs-toggle="modal" data-bs-target="#addressSearchModal">
                  <i class="bi bi-search me-1"></i>Search Address
                </button>
              </div>
            </div>
          </div>

          <!-- Location Coordinates -->
          <div class="row mb-4">
            <div class="col-md-6">
              <%= form.label :center_latitude, "Latitude", class: "form-label fw-semibold" %>
              <%= form.number_field :center_latitude, 
                  step: :any, 
                  class: "form-control", 
                  placeholder: "40.7128", 
                  value: @patient.latitude,
                  required: true %>
              <div class="invalid-feedback">Please provide a valid latitude</div>
            </div>
            <div class="col-md-6">
              <%= form.label :center_longitude, "Longitude", class: "form-label fw-semibold" %>
              <%= form.number_field :center_longitude, 
                  step: :any, 
                  class: "form-control", 
                  placeholder: "-74.0060", 
                  value: @patient.longitude,
                  required: true %>
              <div class="invalid-feedback">Please provide a valid longitude</div>
            </div>
          </div>

          <!-- Radius Configuration -->
          <div class="mb-4">
            <%= form.label :radius_meters, "Safety Zone Radius", class: "form-label fw-semibold" %>
            <div class="row align-items-center">
              <div class="col-md-8">
                <%= form.range_field :radius_meters, 
                    min: 50, 
                    max: 2000, 
                    value: 500,
                    class: "form-range",
                    oninput: "updateRadiusDisplay(this.value)" %>
              </div>
              <div class="col-md-4">
                <div class="input-group">
                  <%= form.number_field :radius_meters, 
                      min: 50, 
                      max: 5000, 
                      value: 500,
                      class: "form-control",
                      id: "radiusInput",
                      oninput: "updateRadiusSlider(this.value)" %>
                  <span class="input-group-text">meters</span>
                </div>
              </div>
            </div>
            <div class="form-text">
              <div id="radiusDescription">Medium zone (500m) - Good for neighborhood safety</div>
              <small class="text-muted">
                • Small (50-200m): Home/building safety
                • Medium (200-800m): Neighborhood safety  
                • Large (800m+): Area/district safety
              </small>
            </div>
          </div>

          <!-- Zone Settings -->
          <div class="row mb-4">
            <div class="col-md-6">
              <div class="form-check form-switch">
                <%= form.check_box :active, class: "form-check-input", checked: true %>
                <%= form.label :active, "Activate Zone Immediately", class: "form-check-label fw-semibold" %>
              </div>
              <div class="form-text">Zone will start monitoring as soon as it's created</div>
            </div>
          </div>

          <!-- Preview Map -->
          <div class="mb-4">
            <label class="form-label fw-semibold">Zone Preview</label>
            <div class="border rounded" style="height: 300px;">
              <div id="previewMap" style="height: 100%;"></div>
            </div>
            <div class="form-text">Preview shows the zone location and radius</div>
          </div>

          <!-- Action Buttons -->
          <div class="d-flex gap-2">
            <%= form.submit "Create Geofence Zone", class: "btn btn-primary" %>
            <%= link_to [@patient], class: "btn btn-outline-secondary" do %>
              Cancel
            <% end %>
            <button type="button" class="btn btn-outline-info" onclick="testZoneContainment()">
              <i class="bi bi-check-circle me-1"></i>Test Zone
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Address Search Modal -->
<div class="modal fade" id="addressSearchModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Search Location</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Enter Address or Location</label>
          <input type="text" class="form-control" id="addressSearch" placeholder="123 Main St, New York, NY">
        </div>
        <div id="searchResults" class="list-group"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="searchLocation()">Search</button>
      </div>
    </div>
  </div>
</div>

<script>
let previewMap;
let zoneCircle;
let patientMarker;

// Initialize preview map
document.addEventListener('DOMContentLoaded', function() {
  initializePreviewMap();
  
  // Form validation
  const form = document.querySelector('.needs-validation');
  form.addEventListener('submit', function(event) {
    if (!form.checkValidity()) {
      event.preventDefault();
      event.stopPropagation();
    }
    form.classList.add('was-validated');
  });
});

function initializePreviewMap() {
  previewMap = L.map('previewMap').setView([<%= @patient.latitude %>, <%= @patient.longitude %>], 14);
  
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors'
  }).addTo(previewMap);

  // Add patient marker
  patientMarker = L.marker([<%= @patient.latitude %>, <%= @patient.longitude %>])
    .bindPopup('<%= @patient.name %> (Current Location)')
    .addTo(previewMap);

  // Add initial zone circle
  updatePreviewZone();
  
  // Update preview when coordinates change
  document.getElementById('geofence_zone_center_latitude').addEventListener('input', updatePreviewZone);
  document.getElementById('geofence_zone_center_longitude').addEventListener('input', updatePreviewZone);
  
  // Allow map clicks to set location
  previewMap.on('click', function(e) {
    document.getElementById('geofence_zone_center_latitude').value = e.latlng.lat.toFixed(6);
    document.getElementById('geofence_zone_center_longitude').value = e.latlng.lng.toFixed(6);
    updatePreviewZone();
  });
}

function updatePreviewZone() {
  const lat = parseFloat(document.getElementById('geofence_zone_center_latitude').value) || <%= @patient.latitude %>;
  const lng = parseFloat(document.getElementById('geofence_zone_center_longitude').value) || <%= @patient.longitude %>;
  const radius = parseInt(document.getElementById('geofence_zone_radius_meters').value) || 500;

  if (zoneCircle) {
    previewMap.removeLayer(zoneCircle);
  }

  zoneCircle = L.circle([lat, lng], {
    color: '#198754',
    fillColor: '#d1e7dd',
    fillOpacity: 0.3,
    radius: radius,
    weight: 2
  }).addTo(previewMap);

  // Center map on zone
  previewMap.setView([lat, lng], 15);
}

function updateRadiusDisplay(value) {
  document.getElementById('radiusInput').value = value;
  updatePreviewZone();
  
  const descriptions = {
    50: "Very small zone (50m) - Single building",
    100: "Small zone (100m) - Building complex", 
    200: "Small zone (200m) - City block",
    500: "Medium zone (500m) - Neighborhood area",
    800: "Large zone (800m) - District area",
    1000: "Large zone (1km) - Wide area",
    2000: "Very large zone (2km) - City district"
  };
  
  const closest = Object.keys(descriptions).reduce((prev, curr) => 
    Math.abs(curr - value) < Math.abs(prev - value) ? curr : prev
  );
  
  document.getElementById('radiusDescription').textContent = descriptions[closest];
}

function updateRadiusSlider(value) {
  const slider = document.getElementById('geofence_zone_radius_meters');
  if (value >= slider.min && value <= slider.max) {
    slider.value = value;
  }
  updateRadiusDisplay(value);
}

function useCurrentLocation() {
  document.getElementById('geofence_zone_center_latitude').value = <%= @patient.latitude %>;
  document.getElementById('geofence_zone_center_longitude').value = <%= @patient.longitude %>;
  updatePreviewZone();
}

function useMapClick() {
  alert('Click anywhere on the preview map to set the zone center location.');
}

function searchLocation() {
  const query = document.getElementById('addressSearch').value;
  if (!query) return;
  
  // In a real application, you would use a geocoding service here
  alert('Location search would be implemented with a geocoding service like Google Maps API or Nominatim.');
}

function testZoneContainment() {
  const patientLat = <%= @patient.latitude %>;
  const patientLng = <%= @patient.longitude %>;
  const zoneLat = parseFloat(document.getElementById('geofence_zone_center_latitude').value);
  const zoneLng = parseFloat(document.getElementById('geofence_zone_center_longitude').value);
  const radius = parseInt(document.getElementById('geofence_zone_radius_meters').value);
  
  // Simple distance calculation
  const distance = getDistance(patientLat, patientLng, zoneLat, zoneLng);
  const isInside = distance <= radius;
  
  const message = isInside 
    ? `✅ Patient is INSIDE the zone (${distance.toFixed(0)}m from center)`
    : `⚠️ Patient is OUTSIDE the zone (${distance.toFixed(0)}m from center, radius: ${radius}m)`;
    
  alert(message);
}

function getDistance(lat1, lng1, lat2, lng2) {
  const R = 6371000; // Earth radius in meters
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLng = (lng2 - lng1) * Math.PI / 180;
  const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
            Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
            Math.sin(dLng/2) * Math.sin(dLng/2);
  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  return R * c;
}
</script>

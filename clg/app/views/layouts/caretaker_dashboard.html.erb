<!DOCTYPE html>
<html>
  <head>
    <title>Caretaker Dashboard - Patient Monitoring</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <!-- Chart.js for vital signs charts -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Leaflet for maps -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
  </head>

  <body class="d-flex">
    <!-- Sidebar -->
    <div class="bg-dark text-white sidebar" style="min-height: 100vh; width: 250px;">
      <div class="p-3 border-bottom border-secondary">
        <div class="d-flex align-items-center">
          <i class="bi bi-heart-pulse-fill fs-4 me-2 text-danger"></i>
          <div>
            <h6 class="mb-0">Caretaker Portal</h6>
            <small class="text-muted">Patient Monitoring</small>
          </div>
        </div>
      </div>
      
      <div class="p-3 border-bottom border-secondary">
        <div class="d-flex align-items-center">
          <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-2" 
               style="width: 40px; height: 40px;">
            <i class="bi bi-person-badge text-white"></i>
          </div>
          <div>
            <div class="fw-bold"><%= current_caretaker.display_name %></div>
            <small class="text-muted"><%= current_caretaker.specialization %></small>
          </div>
        </div>
      </div>
      
      <nav class="nav flex-column p-3">
        <%= link_to caretakers_root_path, class: "nav-link text-white #{'active bg-primary rounded' if current_page?(caretakers_root_path)}" do %>
          <i class="bi bi-speedometer2 me-2"></i>Dashboard
        <% end %>
        
        <%= link_to caretakers_patients_path, class: "nav-link text-white #{'active bg-primary rounded' if current_page?(caretakers_patients_path)}" do %>
          <i class="bi bi-people me-2"></i>My Patients
          <span class="badge bg-primary ms-auto"><%= current_caretaker.total_patients_count %></span>
        <% end %>
        
        <hr class="border-secondary">
        
        <div class="nav-link text-muted small">QUICK STATS</div>
        
        <div class="nav-link text-white d-flex justify-content-between">
          <span><i class="bi bi-person-check me-2"></i>Primary Patients</span>
          <span class="badge bg-success"><%= current_caretaker.primary_patients_count %></span>
        </div>
        
        <div class="nav-link text-white d-flex justify-content-between">
          <span><i class="bi bi-exclamation-triangle me-2"></i>Need Attention</span>
          <span class="badge bg-warning"><%= current_caretaker.patients_needing_attention.count %></span>
        </div>
        
        <div class="nav-link text-white d-flex justify-content-between">
          <span><i class="bi bi-heart-pulse me-2"></i>Critical Alerts</span>
          <span class="badge bg-danger"><%= current_caretaker.critical_alerts_count %></span>
        </div>
      </nav>
      
      <div class="mt-auto p-3 border-top border-secondary">
        <%= link_to "Settings", "#", class: "nav-link text-white" %>
        <%= link_to destroy_caretaker_session_path, method: :delete, 
            class: "nav-link text-white", 
            data: { confirm: "Are you sure you want to sign out?" } do %>
          <i class="bi bi-box-arrow-right me-2"></i>Sign Out
        <% end %>
      </div>
    </div>
    
    <!-- Main Content -->
    <div class="flex-grow-1 bg-light">
      <!-- Top Navigation -->
      <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
        <div class="container-fluid">
          <div class="d-flex align-items-center">
            <span class="navbar-text me-3">
              <i class="bi bi-calendar3 me-1"></i>
              <%= Date.current.strftime("%B %d, %Y") %>
            </span>
            <span class="navbar-text">
              <i class="bi bi-clock me-1"></i>
              <span id="currentTime"></span>
            </span>
          </div>
          
          <div class="d-flex align-items-center">
            <span class="badge bg-success me-2" id="connectionStatus">
              <i class="bi bi-wifi me-1"></i>Connected
            </span>
            <div class="dropdown">
              <button class="btn btn-outline-secondary dropdown-toggle" type="button" 
                      id="notificationsDropdown" data-bs-toggle="dropdown">
                <i class="bi bi-bell"></i>
                <span class="badge bg-danger">3</span>
              </button>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><h6 class="dropdown-header">Recent Alerts</h6></li>
                <li><a class="dropdown-item" href="#">
                  <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                  Patient vital signs warning
                </a></li>
                <li><a class="dropdown-item" href="#">
                  <i class="bi bi-battery text-danger me-2"></i>
                  Device low battery alert
                </a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-center" href="#">View All Alerts</a></li>
              </ul>
            </div>
          </div>
        </div>
      </nav>
      
      <!-- Page Content -->
      <main class="container-fluid p-4">
        <% if notice %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= notice %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% end %>
        
        <% if alert %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= alert %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% end %>
        
        <%= yield %>
      </main>
    </div>
    
    <script>
      // Update current time
      function updateTime() {
        const now = new Date();
        document.getElementById('currentTime').textContent = now.toLocaleTimeString();
      }
      
      updateTime();
      setInterval(updateTime, 1000);
      
      // Connection status simulation
      function updateConnectionStatus() {
        const statusEl = document.getElementById('connectionStatus');
        // In a real app, check actual connection status
        statusEl.innerHTML = '<i class="bi bi-wifi me-1"></i>Connected';
        statusEl.className = 'badge bg-success me-2';
      }
      
      setInterval(updateConnectionStatus, 5000);
    </script>
  </body>
</html>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="fw-bold text-dark mb-1">Patient Management</h2>
    <p class="text-muted mb-0">Monitor and manage your patients</p>
  </div>
  <div>
    <%= link_to "Add New Patient", new_patient_path, class: "btn btn-primary" %>
  </div>
</div>

<!-- Patients List -->
<div class="card">
  <div class="card-header bg-white border-bottom">
    <h5 class="card-title mb-0">
      <i class="bi bi-people-fill me-2 text-primary"></i>
      All Patients (<%= @patients.count %>)
    </h5>
  </div>
  <div class="card-body p-0">
    <% if @patients.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Patient</th>
              <th>Status</th>
              <th>Location</th>
              <th>Latest Vitals</th>
              <th>Last Seen</th>
              <th>Geofence Zones</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @patients.each do |patient| %>
              <tr>
                <td>
                  <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3" 
                         style="width: 45px; height: 45px; font-size: 18px;">
                      <%= patient.name.first.upcase %>
                    </div>
                    <div>
                      <div class="fw-bold"><%= patient.name %></div>
                      <div class="text-muted small">
                        <%= patient.age %> years • <%= patient.gender.capitalize %>
                      </div>
                    </div>
                  </div>
                </td>
                <td>
                  <span class="badge bg-<%= patient.status_color %> fs-6">
                    <i class="bi bi-circle-fill me-1"></i>
                    <%= patient.location_status.humanize %>
                  </span>
                </td>
                <td>
                  <% if patient.latitude && patient.longitude %>
                    <div class="small">
                      <i class="bi bi-geo-alt-fill text-primary me-1"></i>
                      <%= patient.latitude.round(4) %>, <%= patient.longitude.round(4) %>
                    </div>
                  <% else %>
                    <span class="text-muted">No location data</span>
                  <% end %>
                </td>
                <td>
                  <% latest_vitals = patient.latest_vital_signs %>
                  <% if latest_vitals %>
                    <div class="small">
                      <div>
                        <i class="bi bi-heart-pulse-fill text-danger me-1"></i>
                        <%= latest_vitals.heart_rate %> BPM
                      </div>
                      <div>
                        <i class="bi bi-droplet-fill text-primary me-1"></i>
                        <%= latest_vitals.blood_pressure_systolic %>/<%= latest_vitals.blood_pressure_diastolic %>
                      </div>
                      <div>
                        <i class="bi bi-thermometer-half text-warning me-1"></i>
                        <%= latest_vitals.temperature %>°F
                      </div>
                    </div>
                  <% else %>
                    <span class="text-muted">No vital signs</span>
                  <% end %>
                </td>
                <td>
                  <% if patient.last_seen_at %>
                    <div class="small">
                      <%= time_ago_in_words(patient.last_seen_at) %> ago
                    </div>
                    <div class="text-muted small">
                      <%= patient.last_seen_at.strftime("%m/%d %I:%M %p") %>
                    </div>
                  <% else %>
                    <span class="text-muted">Never</span>
                  <% end %>
                </td>
                <td>
                  <div class="small">
                    <% patient.geofence_zones.active.each do |zone| %>
                      <span class="badge bg-light text-dark me-1">
                        <i class="bi bi-geo-alt me-1"></i>
                        <%= zone.name %>
                      </span>
                    <% end %>
                    <% if patient.geofence_zones.active.empty? %>
                      <span class="text-muted">No zones</span>
                    <% end %>
                  </div>
                </td>
                <td>
                  <div class="btn-group" role="group">
                    <%= link_to patient_path(patient), class: "btn btn-sm btn-outline-primary" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to edit_patient_path(patient), class: "btn btn-sm btn-outline-secondary" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <%= link_to patient_path(patient), method: :delete, 
                        data: { 
                          "turbo-method": :delete,
                          "turbo-confirm": "Are you sure you want to delete this patient?" 
                        }, 
                        class: "btn btn-sm btn-outline-danger" do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-5">
        <i class="bi bi-people display-1 text-muted mb-3"></i>
        <h5 class="text-muted">No Patients Added</h5>
        <p class="text-muted mb-4">Start monitoring by adding your first patient.</p>
        <%= link_to "Add Your First Patient", new_patient_path, class: "btn btn-primary btn-lg" %>
      </div>
    <% end %>
  </div>
</div>
